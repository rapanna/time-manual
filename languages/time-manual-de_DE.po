#, php-format
msgid "The ZIP could not be extracted: %s"
msgstr "Die ZIP-Datei konnte nicht entpackt werden: %s"

#: includes/import.php:94
msgid "The manual.json file is missing from the ZIP."
msgstr "In der ZIP-Datei fehlt die Datei manual.json."

#: includes/import.php:102
msgid "manual.json is corrupted or empty."
msgstr "manual.json ist beschädigt oder leer."

#. translators: %s: number of imported manuals.
#: includes/import.php:120
#, php-format
msgid "%s manual imported."
msgid_plural "%s manuals imported."
msgstr[0] "%s Handbuch importiert."
msgstr[1] "%s Handbücher importiert."

#: includes/metabox.php:36
msgid "Role visibility"
msgstr "Sichtbarkeit für Rollen"

#: includes/metabox.php:58
msgid "No role is allowed to read manuals yet. Set them up in Manuals → Settings."
msgstr "Bisher darf keine Rolle Handbücher lesen. Legen Sie das unter Handbücher → Einstellungen fest."

#: includes/metabox.php:62
msgid "Select the roles that will see this manual. Nothing checked = everyone allowed will see it."
msgstr "Wählen Sie die Rollen aus, die dieses Handbuch sehen. Nichts ausgewählt = alle Berechtigten sehen es."

#: includes/settings.php:16
#: includes/settings.php:50
msgid "Manuals Settings"
msgstr "Handbuch-Einstellungen"

#: includes/settings.php:17
msgid "Settings"
msgstr "Einstellungen"

#: includes/settings.php:42
msgid "Settings saved. Role capabilities have been synchronized."
msgstr "Einstellungen gespeichert. Die Berechtigungen der Rollen wurden synchronisiert."

#. translators: %s: Administrator role name, wrapped in <strong>.
#: includes/settings.php:56
#, php-format
msgid "Select the roles allowed to read internal manuals. Other roles will not see the manuals on the dashboard at all. %s always has access."
msgstr "Wählen Sie die Rollen aus, die interne Handbücher lesen dürfen. Andere Rollen sehen die Handbücher im Dashboard überhaupt nicht. %s hat immer Zugriff."

#: includes/settings.php:65
msgid "Roles with access"
msgstr "Rollen mit Zugriff"

#: includes/metabox.php:68
#: includes/settings.php:70
msgid "Select all"
msgstr "Alle auswählen"

#: includes/settings.php:83
msgid "Do not try to handle a site with thousands of cloned roles here — the capability can be assigned in bulk with a one-off script."
msgstr "Eine Website mit Tausenden geklonten Rollen sollte hier nicht verwaltet werden – die Berechtigung lässt sich per einmaligem Skript massenhaft zuweisen."

#: includes/settings.php:88
msgid "Save Settings"
msgstr "Einstellungen speichern"
