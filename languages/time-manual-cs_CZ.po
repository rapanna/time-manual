#: includes/import.php:31
#: includes/settings.php:26
msgid "Insufficient permissions."
msgstr "Nedostatečná oprávnění."

#: includes/export.php:200
msgid "Select the manuals and download them as a ZIP. The package contains the article content, the configured roles and every media file (images and PDFs) referenced from the content — so it can be imported on another site."
msgstr "Vyber manuály a stáhni je jako ZIP. Balíček obsahuje obsah článků, nastavené role a všechna média (obrázky i PDF) odkazovaná z obsahu – jde tedy naimportovat na jiný web."

#: includes/export.php:203
msgid "There are no manuals to export yet."
msgstr "Zatím zde nejsou žádné manuály k exportu."

#: includes/export.php:213
msgid "Manual"
msgstr "Manuál"

#: includes/export.php:214
msgid "Status"
msgstr "Stav"

#: includes/export.php:226
#: includes/import.php:162
msgid "(no title)"
msgstr "(bez názvu)"

#: includes/export.php:234
msgid "Export selected (ZIP)"
msgstr "Exportovat vybrané (ZIP)"

#: includes/export.php:250
msgid "Export (ZIP)"
msgstr "Exportovat (ZIP)"

#: includes/export.php:276
msgid "No manual was selected for export."
msgstr "Nebyl vybrán žádný manuál k exportu."

#: includes/export.php:277
msgid "Export cannot run: the PHP ZipArchive extension is missing on the server."
msgstr "Export nelze provést: na serveru chybí rozšíření PHP ZipArchive."

#: includes/export.php:278
msgid "Export failed — the ZIP could not be created."
msgstr "Export se nezdařil – ZIP se nepodařilo vytvořit."

#: includes/import.php:21
#: includes/import.php:40
msgid "Import Manuals"
msgstr "Import manuálů"

#: includes/import.php:22
#: includes/import.php:51
msgid "Import"
msgstr "Import"

#: includes/import.php:41
msgid "Upload a ZIP created by the manuals export. Media will be downloaded into this site’s library and the links in the content will be rewritten. Role visibility will be set to this site’s defaults."
msgstr "Nahraj ZIP vytvořený exportem manuálů. Média se stáhnou do knihovny tohoto webu a odkazy v obsahu se přepíší. Viditelnost pro role se nastaví na výchozí hodnoty tohoto webu."

#: includes/import.php:47
msgid "ZIP file"
msgstr "Soubor ZIP"

#: includes/import.php:60
msgid "No file was selected."
msgstr "Nebyl vybrán žádný soubor."

#: includes/import.php:65
msgid "Error while uploading the file."
msgstr "Chyba při nahrávání souboru."

#. translators: %s: error message returned by unzip_file().
#: includes/import.php:84
#, php-format
msgid "The ZIP could not be extracted: %s"
msgstr "ZIP se nepodařilo rozbalit: %s"

#: includes/import.php:94
msgid "The manual.json file is missing from the ZIP."
msgstr "V ZIPu chybí soubor manual.json."

#: includes/import.php:102
msgid "manual.json is corrupted or empty."
msgstr "manual.json je poškozený nebo prázdný."

#. translators: %s: number of imported manuals.
#: includes/import.php:120
#, php-format
msgid "%s manual imported."
msgid_plural "%s manuals imported."
msgstr[0] "Importován %s manuál."
msgstr[1] "Importovány %s manuály."
msgstr[2] "Importováno %s manuálů."

#: includes/metabox.php:36
msgid "Role visibility"
msgstr "Viditelnost pro role"

#: includes/metabox.php:58
msgid "No role is allowed to read manuals yet. Set them up in Manuals → Settings."
msgstr "Zatím žádné role nemají oprávnění ke čtení manuálů. Nastav je v Manuály → Nastavení."

#: includes/metabox.php:62
msgid "Select the roles that will see this manual. Nothing checked = everyone allowed will see it."
msgstr "Vyber role, které tento manuál uvidí. Nezaškrtnuto = uvidí všichni oprávnění."

#: includes/settings.php:16
#: includes/settings.php:50
msgid "Manuals Settings"
msgstr "Nastavení manuálů"

#: includes/settings.php:17
msgid "Settings"
msgstr "Nastavení"

#: includes/settings.php:42
msgid "Settings saved. Role capabilities have been synchronized."
msgstr "Nastavení uloženo. Oprávnění rolí byla synchronizována."

#. translators: %s: Administrator role name, wrapped in <strong>.
#: includes/settings.php:54
#, php-format
msgid "Select the roles allowed to read internal manuals. Other roles will not see the manuals on the dashboard at all. %s always has access."
msgstr "Vyber role, které smí číst interní manuály. Ostatní role manuály na nástěnce vůbec neuvidí. %s má přístup vždy."

#: includes/settings.php:63
msgid "Roles with access"
msgstr "Role s přístupem"

#: includes/settings.php:80
msgid "Do not try to handle a site with thousands of cloned roles here — the capability can be assigned in bulk with a one-off script."
msgstr "Web s tisíci klony rolí zde neřeš — capability lze hromadně přiřadit jednorázovým skriptem."

#: includes/settings.php:85
msgid "Save Settings"
msgstr "Uložit nastavení"
